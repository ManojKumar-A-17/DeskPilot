        "authentication": "oAuth2",
        "sendTo": "={{ $json.userEmail }}",
        "subject": "=✅ Ticket {{ $json.ticketNumber }} Assigned",
        "emailType": "html",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: 'Segoe UI', Arial, sans-serif; line-height: 1.6; color: #333; background: #f5f5f5; }\n    .email-wrapper { background: #f5f5f5; padding: 20px; }\n    .email-container { max-width: 600px; margin: 0 auto; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }\n    .header { background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%); color: white; padding: 30px 20px; text-align: center; }\n    .header h1 { font-size: 24px; margin-bottom: 8px; }\n    .header p { font-size: 14px; opacity: 0.9; }\n    .content { padding: 30px 20px; }\n    .greeting { font-size: 16px; margin-bottom: 20px; }\n    .info-card { background: #f9f9f9; border-left: 4px solid #FF6B35; padding: 20px; margin: 20px 0; border-radius: 8px; }\n    .info-row { padding: 8px 0; border-bottom: 1px solid #eee; }\n    .info-row:last-child { border-bottom: none; }\n    .label { font-weight: 600; color: #FF6B35; display: inline-block; min-width: 140px; }\n    .value { color: #555; }\n    .cta-button { display: inline-block; background: linear-gradient(135deg, #FF6B35 0%, #F7931E 100%); color: white; text-decoration: none; padding: 14px 32px; border-radius: 8px; margin: 20px 0; font-weight: 600; text-align: center; }\n    .cta-button:hover { opacity: 0.9; }\n    .footer { background: #f9f9f9; padding: 20px; text-align: center; font-size: 12px; color: #999; border-top: 1px solid #eee; }\n    .priority-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }\n    .priority-high { background: #ffebee; color: #c62828; }\n    .priority-medium { background: #fff3e0; color: #ef6c00; }\n    .priority-low { background: #e8f5e9; color: #2e7d32; }\n    .priority-critical { background: #ffcdd2; color: #b71c1c; }\n  </style>\n</head>\n<body>\n  <div class=\"email-wrapper\">\n    <div class=\"email-container\">\n      <div class=\"header\">\n        <h1>🎫 Technician Assigned!</h1>\n        <p>ThinkAuto AI HelpDesk System</p>\n      </div>\n      <div class=\"content\">\n        <p class=\"greeting\">Hello <strong>{{ $json.userName }}</strong>,</p>\n        <p>Great news! Your support ticket has been assigned to a technician who will help resolve your issue.</p>\n        \n        <div class=\"info-card\">\n          <div class=\"info-row\">\n            <span class=\"label\">Ticket Number:</span>\n            <span class=\"value\"><strong>{{ $json.ticketNumber }}</strong></span>\n          </div>\n          <div class=\"info-row\">\n            <span class=\"label\">Title:</span>\n            <span class=\"value\">{{ $json.ticketTitle }}</span>\n          </div>\n          <div class=\"info-row\">\n            <span class=\"label\">Priority:</span>\n            <span class=\"value\">\n              <span class=\"priority-badge priority-{{ $json.ticketPriority.toLowerCase() }}\">{{ $json.ticketPriority }}</span>\n            </span>\n          </div>\n          <div class=\"info-row\">\n            <span class=\"label\">Assigned To:</span>\n            <span class=\"value\"><strong>{{ $json.technicianName }}</strong></span>\n          </div>\n          <div class=\"info-row\">\n            <span class=\"label\">Assignment Reason:</span>\n            <span class=\"value\">{{ $json.assignmentReason }}</span>\n          </div>\n        </div>\n        \n        <p>Your assigned technician will review the details and begin working on your ticket shortly. You'll receive updates as progress is made.</p>\n        \n        <center>\n          <a href=\"http://localhost:8081/employee/tickets/{{ $json.ticketId }}\" class=\"cta-button\">📊 View Ticket Status</a>\n        </center>\n      </div>\n      <div class=\"footer\">\n        <p>This is an automated notification from ThinkAuto HelpDesk</p>\n        <p>Please do not reply to this email</p>\n        <p style=\"margin-top: 10px; color: #bbb;\">© 2026 ThinkAuto. All rights reserved.</p>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",
        "options": {}
