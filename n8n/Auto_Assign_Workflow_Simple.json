      "id": "3",
      "name": "Get All Technicians",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "// Smart Assignment Logic - No AI needed!\nconst ticket = $('Get Ticket Details').first().json.data.ticket;\nconst techniciansResponse = $('Get All Technicians').first().json;\nconst technicians = techniciansResponse.data.users;\n\nif (!technicians || technicians.length === 0) {\n  throw new Error('No technicians available');\n}\n\n// Get workload for each technician\nconst techWithWorkload = [];\nfor (const tech of technicians) {\n  // Count active tickets (you can fetch this from API or assume 0 for now)\n  techWithWorkload.push({\n    ...tech,\n    workload: 0 // Will be calculated by checking assignedTo field\n  });\n}\n\n// Smart selection logic:\n// 1. Match by department/category (if available)\n// 2. Select technician with lowest workload\n// 3. Round-robin if equal workload\n\nconst ticketCategory = ticket.category.toLowerCase();\nlet selectedTech = null;\nlet reason = '';\n\n// Try to match by department\nconst matchingDept = techWithWorkload.filter(t => \n  t.department && t.department.toLowerCase().includes(ticketCategory)\n);\n\nif (matchingDept.length > 0) {\n  // Found department match - pick one with lowest workload\n  selectedTech = matchingDept.sort((a, b) => a.workload - b.workload)[0];\n  reason = `Matched department expertise for ${ticketCategory}`;\n} else {\n  // No department match - pick available technician with lowest workload\n  selectedTech = techWithWorkload.sort((a, b) => a.workload - b.workload)[0];\n  reason = 'Selected based on current workload availability';\n}\n\n// Prepare output data\nreturn {\n  ticketId: ticket._id,\n  ticketNumber: ticket.ticketNumber,\n  ticketTitle: ticket.title,\n  ticketDescription: ticket.description,\n  ticketPriority: ticket.priority,\n  ticketCategory: ticket.category,\n  technicianId: selectedTech._id,\n  technicianName: selectedTech.name,\n  technicianEmail: selectedTech.email,\n  userName: ticket.createdBy.name,\n  userEmail: ticket.createdBy.email,\n  assignmentReason: reason,\n  currentWorkload: selectedTech.workload\n};"
      },
      "id": "4",
      "name": "Smart Assignment Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
